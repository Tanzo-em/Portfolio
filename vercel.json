{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "dist/**", "use": "@vercel/static" },
    { "src": "api/**/*.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "^/api/contact$", "dest": "api/contact.ts" },
    { "src": "^/api/contacts$", "dest": "api/contacts.ts" },
    { "src": "^(?!/api/).*$", "dest": "/index.html" }
  ]
}